ngx_addon_name=ngx_http_lua_module

ngx_lua_src="$ngx_addon_dir/lua-5.5.0/src"
ngx_lua_lib="$ngx_lua_src/liblua.a"
ngx_lua_module_deps="$ngx_addon_dir/src/ngx_lua.h \
    $ngx_addon_dir/src/ngx_lua_web.h \
    $ngx_addon_dir/src/ngx_http_lua.h \
    $ngx_lua_lib"
ngx_lua_libs="$ngx_lua_lib -lm $NGX_LIBDL"
ngx_lua_module_src="$ngx_addon_dir/src/ngx_http_lua_module.c \
    $ngx_addon_dir/src/ngx_lua.c \
    $ngx_addon_dir/src/ngx_lua_web_request.c \
    $ngx_addon_dir/src/ngx_lua_web_response.c \
    $ngx_addon_dir/src/ngx_lua_web_headers.c \
    $ngx_addon_dir/src/ngx_lua_web_url.c \
    $ngx_addon_dir/src/ngx_lua_web_search_params.c \
    $ngx_addon_dir/src/ngx_lua_web_stream.c \
    $ngx_addon_dir/src/ngx_http_lua_fetch.c \
    $ngx_addon_dir/src/ngx_lua_app.c \
    $ngx_addon_dir/src/ngx_http_lua_request.c \
    $ngx_addon_dir/src/ngx_http_lua_response.c"

if test ! -f "$ngx_lua_src/Makefile"; then
    echo "$0: error: Lua 5.5 source Makefile not found in $ngx_lua_src"
    exit 1
fi

LINK_DEPS="$LINK_DEPS $ngx_lua_lib"

if test -n "$ngx_module_link"; then
    ngx_module_type=HTTP
    ngx_module_name=ngx_http_lua_module
    ngx_module_incs="$ngx_lua_src"
    ngx_module_deps="$ngx_lua_module_deps"
    ngx_module_srcs="$ngx_lua_module_src"
    ngx_module_libs="$ngx_lua_libs"

    . auto/module
else
    HTTP_MODULES="$HTTP_MODULES ngx_http_lua_module"
    NGX_ADDON_SRCS="$NGX_ADDON_SRCS $ngx_lua_module_src"
    NGX_ADDON_DEPS="$NGX_ADDON_DEPS $ngx_lua_module_deps"
    CORE_INCS="$CORE_INCS $ngx_lua_src"
    CORE_LIBS="$CORE_LIBS $ngx_lua_libs"
fi
